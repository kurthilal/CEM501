# ============================================================
# CEM501 AI Email Agent -- Environment Variables
# ============================================================
# Copy this file to .env and fill in your actual values:
#   cp .env.example .env
#
# IMPORTANT: Never commit your .env file to version control.
# ============================================================

# --- LLM API Keys ---

# Anthropic API key for Claude (used for email classification and drafting)
# Get yours at: https://console.anthropic.com/
ANTHROPIC_API_KEY=your_key_here

# Optional: model ID for Messages API (defaults to claude-sonnet-4-6 in code if unset)
# ANTHROPIC_MODEL=claude-sonnet-4-6

# OpenAI API key (optional, if using GPT models as alternative)
# Get yours at: https://platform.openai.com/api-keys
OPENAI_API_KEY=your_key_here

# --- Email Configuration ---

# The email address your agent will read from and send through
EMAIL_ADDRESS=your_email@example.com

# App-specific password (NOT your regular email password)
# For Gmail: https://myaccount.google.com/apppasswords
EMAIL_PASSWORD=your_app_password

# IMAP server for reading incoming emails
IMAP_SERVER=imap.gmail.com

# SMTP server and port for sending outgoing emails
SMTP_SERVER=smtp.gmail.com
SMTP_PORT=587

# --- Messaging Integration (Optional) ---

# Telegram bot token for notifications and draft approval
# Create a bot via @BotFather on Telegram
TELEGRAM_BOT_TOKEN=your_token_here

# --- Web dashboard (demo/web/app.py) ---
# WEB_PORT=5000
# WEB_ALLOW_SEND=1   # allow browser SMTP (/api/send) and Telegram replies (/api/telegram/send)
